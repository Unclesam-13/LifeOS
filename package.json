{
    "name":  "life-manager-dashboard",
    "version":  "0.1.2",
    "description":  "A visual life management dashboard that uses Markdown as a local database.",
    "main":  "main.js",
    "scripts":  {
                    "dev":  "node esbuild.config.mjs --watch",
                    "build":  "tsc -noEmit -skipLibCheck \u0026\u0026 node esbuild.config.mjs production"
                },
    "keywords":  [
                     "obsidian",
                     "plugin",
                     "life-management",
                     "markdown"
                 ],
    "author":  "steven",
    "license":  "MIT",
    "devDependencies":  {
                            "@types/node":  "^20.11.30",
                            "builtin-modules":  "^3.3.0",
                            "esbuild":  "^0.25.5",
                            "obsidian":  "^1.8.7",
                            "tslib":  "^2.6.2",
                            "typescript":  "^5.4.5"
                        }
}
